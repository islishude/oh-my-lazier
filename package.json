{
  "name": "oh-my-lazier",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted LayerZero V2 Executor and DVN worker stack.",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:scripts": "tsx --test contracts/scripts/*.test.ts",
    "typecheck": "tsc --noEmit",
    "deploy:open-workers": "hardhat ignition deploy ignition/modules/OpenWorkers.ts",
    "deploy:open-dvn-worker": "hardhat ignition deploy ignition/modules/OpenDVNWorker.ts",
    "deploy:test-oft": "hardhat ignition deploy ignition/modules/TestOFT.ts",
    "configure:oapp-endpoint": "hardhat ignition deploy ignition/modules/OAppEndpointConfig.ts",
    "configure:open-workers-pathway": "hardhat ignition deploy ignition/modules/OpenWorkersPathwayConfig.ts",
    "configure:open-dvn-pathway": "hardhat ignition deploy ignition/modules/OpenDVNPathwayConfig.ts",
    "deploy:profile": "tsx contracts/scripts/deploy-profile.ts",
    "render:oft-pathway-params": "tsx contracts/scripts/render-oft-pathway-params.ts",
    "configure:workers": "tsx contracts/scripts/configure-workers.ts",
    "generate:lzabi": "npm run compile && tsx contracts/scripts/generate-lzabi.ts",
    "check:lzabi": "npm run compile && tsx contracts/scripts/generate-lzabi.ts --check",
    "generate:pricing-abi": "npm run compile && tsx contracts/scripts/generate-pricing-abi.ts",
    "check:pricing-abi": "npm run compile && tsx contracts/scripts/generate-pricing-abi.ts --check",
    "inspect:lz-config": "tsx contracts/scripts/inspect-lz-config.ts",
    "configure:lz-executor": "tsx contracts/scripts/configure-lz-executor.ts",
    "configure:lz-dvn": "tsx contracts/scripts/configure-lz-dvn.ts",
    "configure:lz-rollback": "tsx contracts/scripts/configure-lz-rollback.ts",
    "send:oft": "tsx contracts/scripts/send-oft.ts",
    "send:oft-canary": "tsx contracts/scripts/send-oft-canary.ts",
    "check:oft-canary": "tsx contracts/scripts/check-oft-canary.ts",
    "check:dvn-verification": "tsx contracts/scripts/check-dvn-verification.ts",
    "check:lz-addresses": "tsx contracts/scripts/check-lz-addresses.ts",
    "check:deployment-preflight": "tsx contracts/scripts/deployment-preflight.ts",
    "oft:pathway": "tsx contracts/scripts/oft-pathway-control.ts",
    "check:price-config": "tsx contracts/scripts/price-config-check.ts",
    "e2e:deploy-local": "tsx contracts/scripts/e2e-local-deploy.ts",
    "e2e:run-local": "tsx contracts/scripts/e2e-local-run.ts",
    "check:migration-evidence": "tsx contracts/scripts/migration-evidence.ts",
    "check:npm-audit-disposition": "tsx contracts/scripts/npm-audit-disposition.ts",
    "check:security-review": "tsx contracts/scripts/security-review.ts",
    "check:runbooks": "tsx contracts/scripts/runbook-review.ts",
    "check": "npm run compile && npm test && npm run test:scripts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/islishude/oh-my-lazier.git"
  },
  "keywords": [],
  "author": "islishude <islishude@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/islishude/oh-my-lazier/issues"
  },
  "homepage": "https://github.com/islishude/oh-my-lazier#readme",
  "dependencies": {
    "@layerzerolabs/lz-definitions": "3.1.5",
    "@layerzerolabs/lz-evm-messagelib-v2": "3.0.168",
    "@layerzerolabs/lz-evm-oapp-v2": "3.0.168",
    "@layerzerolabs/lz-evm-protocol-v2": "3.0.168",
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@openzeppelin/contracts": "5.6.1",
    "@types/node": "26.1.0",
    "@uniswap/v3-periphery": "1.4.4",
    "hardhat": "3.9.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "viem": "2.54.1"
  },
  "overrides": {
    "axios": "1.18.1",
    "elliptic": "6.6.1",
    "undici": "6.27.0",
    "ws": "8.21.0"
  }
}
