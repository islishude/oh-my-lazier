{
  "name": "oh-my-lazier",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted LayerZero V2 Executor and DVN worker stack.",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:scripts": "tsx --test contracts/scripts/*.test.ts",
    "typecheck": "tsc --noEmit",
    "deploy:workers": "tsx contracts/scripts/deploy-workers.ts",
    "configure:workers": "tsx contracts/scripts/configure-workers.ts",
    "inspect:lz-config": "tsx contracts/scripts/inspect-lz-config.ts",
    "configure:lz-executor": "tsx contracts/scripts/configure-lz-executor.ts",
    "configure:lz-dvn": "tsx contracts/scripts/configure-lz-dvn.ts",
    "check": "npm run compile && npm test && npm run test:scripts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/islishude/oh-my-lazier.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/islishude/oh-my-lazier/issues"
  },
  "homepage": "https://github.com/islishude/oh-my-lazier#readme",
  "dependencies": {
    "@layerzerolabs/lz-evm-messagelib-v2": "3.0.168",
    "@layerzerolabs/lz-evm-oapp-v2": "3.0.168",
    "@layerzerolabs/lz-evm-protocol-v2": "3.0.168",
    "@openzeppelin/contracts": "5.6.1",
    "@types/node": "26.0.1",
    "hardhat": "3.9.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "viem": "2.53.1"
  },
  "overrides": {
    "axios": "1.18.1",
    "elliptic": "6.6.1",
    "undici": "6.27.0",
    "ws": "8.21.0"
  }
}
