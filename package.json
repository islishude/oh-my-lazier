{
  "name": "oh-my-lazier",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted LayerZero V2 Executor and DVN worker stack.",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "npm run check",
    "test:scripts": "hardhat test nodejs --no-compile",
    "typecheck": "tsc --noEmit",
    "deploy:open-workers": "hardhat run --no-compile --build-profile production contracts/scripts/commands/deploy-open-workers.ts",
    "deploy:open-dvn-worker": "hardhat run --no-compile --build-profile production contracts/scripts/commands/deploy-open-dvn-worker.ts",
    "deploy:test-oft": "hardhat run --no-compile --build-profile production contracts/scripts/commands/deploy-test-oft.ts",
    "configure:oapp-endpoint": "hardhat run --no-compile --build-profile production contracts/scripts/commands/configure-oapp-endpoint.ts",
    "configure:open-workers-pathway": "hardhat run --no-compile --build-profile production contracts/scripts/commands/configure-open-workers-pathway.ts",
    "configure:open-dvn-pathway": "hardhat run --no-compile --build-profile production contracts/scripts/commands/configure-open-dvn-pathway.ts",
    "deploy:profile": "hardhat run --no-compile --build-profile production contracts/scripts/commands/deploy-profile.ts",
    "render:oft-pathway-params": "hardhat run --no-compile contracts/scripts/commands/render-oft-pathway-params.ts",
    "configure:workers": "hardhat run --no-compile contracts/scripts/commands/configure-workers.ts",
    "generate:lzabi": "hardhat run --no-compile contracts/scripts/commands/generate-lzabi.ts",
    "check:lzabi": "hardhat run --no-compile contracts/scripts/commands/check-lzabi.ts",
    "generate:pricing-abi": "hardhat run --no-compile contracts/scripts/commands/generate-pricing-abi.ts",
    "check:pricing-abi": "hardhat run --no-compile contracts/scripts/commands/check-pricing-abi.ts",
    "inspect:lz-config": "hardhat run --no-compile contracts/scripts/commands/inspect-lz-config.ts",
    "configure:lz-executor": "hardhat run --no-compile contracts/scripts/commands/configure-lz-executor.ts",
    "configure:lz-dvn": "hardhat run --no-compile contracts/scripts/commands/configure-lz-dvn.ts",
    "configure:lz-rollback": "hardhat run --no-compile contracts/scripts/commands/configure-lz-rollback.ts",
    "send:oft": "hardhat run --no-compile contracts/scripts/commands/send-oft.ts",
    "send:oft-canary": "hardhat run --no-compile contracts/scripts/commands/send-oft-canary.ts",
    "check:oft-canary": "hardhat run --no-compile contracts/scripts/commands/check-oft-canary.ts",
    "check:dvn-verification": "hardhat run --no-compile contracts/scripts/commands/check-dvn-verification.ts",
    "check:lz-addresses": "hardhat run --no-compile contracts/scripts/commands/check-lz-addresses.ts",
    "check:deployment-preflight": "hardhat run --no-compile contracts/scripts/commands/check-deployment-preflight.ts",
    "oft:pathway": "hardhat run --no-compile contracts/scripts/commands/oft-pathway.ts",
    "check:price-config": "hardhat run --no-compile contracts/scripts/commands/check-price-config.ts",
    "e2e:deploy-local": "hardhat run --no-compile --build-profile production contracts/scripts/commands/e2e-local-deploy.ts",
    "e2e:run-local": "hardhat run --no-compile contracts/scripts/commands/e2e-local-run.ts",
    "check:migration-evidence": "hardhat run --no-compile contracts/scripts/commands/check-migration-evidence.ts",
    "check:npm-audit-disposition": "hardhat run --no-compile contracts/scripts/commands/check-npm-audit-disposition.ts",
    "check:security-review": "hardhat run --no-compile contracts/scripts/commands/check-security-review.ts",
    "check:runbooks": "hardhat run --no-compile contracts/scripts/commands/check-runbooks.ts",
    "check": "npm run compile && hardhat test solidity --no-compile && hardhat test nodejs --no-compile"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/islishude/oh-my-lazier.git"
  },
  "keywords": [],
  "author": "islishude <islishude@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/islishude/oh-my-lazier/issues"
  },
  "homepage": "https://github.com/islishude/oh-my-lazier#readme",
  "dependencies": {
    "@layerzerolabs/lz-definitions": "3.1.6",
    "@layerzerolabs/lz-evm-messagelib-v2": "3.0.168",
    "@layerzerolabs/lz-evm-oapp-v2": "3.0.168",
    "@layerzerolabs/lz-evm-protocol-v2": "3.0.168",
    "@chainlink/contracts": "1.5.0",
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@nomicfoundation/ignition-core": "3.1.8",
    "@openzeppelin/contracts": "5.6.1",
    "@types/node": "26.1.1",
    "@uniswap/v3-core": "1.0.1",
    "hardhat": "3.9.1",
    "typescript": "6.0.3",
    "viem": "2.55.2"
  },
  "overrides": {
    "axios": "1.18.1",
    "elliptic": "6.6.1",
    "undici": "6.27.0",
    "ws": "8.21.0"
  }
}
